# Groq API Key (Required for AI Chat features)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs API Key (Optional - for premium TTS voice)
# Get your key from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Telegram Bot Token (Required for Telegram Bot)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Allowed User IDs (Recommended for security)
# Enter your Telegram User ID to allow access to the bot
# Get your User ID by messaging @userinfobot on Telegram
# Leave empty to allow all users (NOT recommended!)
# Example: "123456789,987654321"
TELEGRAM_ALLOWED_USER_IDS=
